# Connection strings for the two Postgres servers used by rank_drop_checker.py.
# Copy to .env and fill in. Values mirror asin_registry/settings.py DATABASES.

# Registry DB ("default") — maps amerge_id -> ASIN (registry_api_asinregistry).
REGISTRY_DB_DSN=postgresql://postgres:PASSWORD@asin-registry.curfkbgd1mw7.eu-west-2.rds.amazonaws.com:5432/postgres

# ROAS DB ("roas") — holds the rank history (public.asin_ranks).
ROAS_DB_DSN=postgresql://roas:PASSWORD@roas.curfkbgd1mw7.eu-west-2.rds.amazonaws.com:5432/postgres
